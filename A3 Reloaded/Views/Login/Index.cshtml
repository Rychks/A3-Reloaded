@{
    Layout = "~/Views/Login/_Login.cshtml";
    ViewBag.Title = "Login";
}
<div class="login-brand">
    <!--<img src="~/Assets/Bayer_Brand/Bayer-Logo2.png" alt="logo" width="100" class="shadow-light rounded-circle">-->
</div>
<style>
</style>
<div class="row">
    <div class="col-lg-12">
        <div class="card" style="border: 1px; padding: 10px; box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19);">
            <div class="row g-0">
                <div class="col-md-4 col-sm-2">
                    <div class="card-body justify-content-center">                       
                        <img src="~/Assets/img/LogoApp/1.png" style="display:block; margin-left:auto; margin-right:auto; width:16vw; height:6vw;" alt="Logo Bayer" />
                        <form method="post" action="@Url.Action("IniciarSesion", "Login")" id="frmLogin_Login">
                            <div class="form-group">
                                <label for="username">CWID</label>
                                <input type="text" id="btnLogin_BYTOST" autocomplete="off" autofocus placeholder="Enter CWID" name="BYTOST" class="form-control form-control-sm">
                            </div>
                            <div class="form-group">
                                <label for="password">Password</label>
                                <input type="password" id="txtLogin_ZNACKA" name="ZNACKA" placeholder="Enter Windows password" class="form-control form-control-sm">
                            </div>
                            <div class="form-group">
                                <label for="txtLogin_Idioma" class="control-label">Language</label>
                                <select id="slc_Idioma" name="ID_Language" style="height:2.3rem !important" class="form-control">
                                    <option value="value">Ingles</option>
                                    <option value="value">Español</option>
                                </select>
                            </div>
                            <button type="submit" id="btnLogin_Entrar" style="width: 100%; height:2.5rem;" class="btn btn-sm btn-block btn-info">Log In</button>
                        </form>
                    </div>
                </div>
                <div class="col-md-8 col-sm-10">
                    <div class="div-animation">
                        <img src="~/Assets/img/mission_officeview.jpg" style="width:100%" class="rounded-start" alt="Logo Bayer">
                    </div>
                  
                </div>

            </div>
        </div>
    </div>
</div>
